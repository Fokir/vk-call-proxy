# Call-VPN Server Configuration
# Copy this file to .env and adjust values as needed.

# Docker image tag (default: latest)
# Use "latest" for latest release, or specific version like "0.20.0"
IMAGE_TAG=latest

# UDP port exposed on host (default: 9000)
LISTEN_PORT=9000

# Auth token for client connections (optional, empty = no auth)
VPN_TOKEN=

# VK call link for relay-to-relay mode (optional)
VK_CALL_LINK=

# Also accept direct DTLS connections on :9000 alongside relay mode (optional)
# Set to "1" to enable both modes simultaneously
ALSO_DIRECT=

# Upstream proxy for client traffic (optional)
# Format: socks5://host:port or http://user:pass@host:port
PROXY_URL=

# Number of parallel TURN connections (default: 16)
TURN_CONNS=16

# Slack webhook URL for monitoring alerts (optional)
SIREN_SLACK_WEBHOOK=

# Captcha service endpoint (default: http://captcha:8090, auto-configured in docker-compose)
# Set to empty to disable captcha solving
CAPTCHA_ENDPOINT=http://captcha:8090

# Captcha service: max concurrent Chrome instances (default: 1)
CAPTCHA_MAX_CONCURRENT=1

# Resource limits — server
MEMORY_LIMIT=256M
CPU_LIMIT=1.0

# Resource limits — captcha service (needs more RAM for Chrome)
CAPTCHA_MEMORY_LIMIT=512M
CAPTCHA_CPU_LIMIT=1.0
