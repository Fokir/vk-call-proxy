# Build stage
FROM golang:1.26-alpine AS builder

RUN apk add --no-cache git

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /captcha-service ./cmd/captcha-service/

# Runtime stage (headless Chrome for captcha solving)
FROM chromedp/headless-shell:latest

COPY --from=builder /captcha-service /usr/local/bin/captcha-service

EXPOSE 8090

ENTRYPOINT ["captcha-service"]
CMD ["--port=8090", "--max-concurrent=1"]
